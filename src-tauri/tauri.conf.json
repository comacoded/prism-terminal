{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PRISM",
  "version": "0.2.0",
  "identifier": "io.nickcoma.prism.spike",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1024,
        "height": 720,
        "minWidth": 560,
        "minHeight": 380,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}