{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PRISM",
  "version": "0.2.3",
  "identifier": "io.nickcoma.prism.spike",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1024,
        "height": 720,
        "minWidth": 560,
        "minHeight": 380,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "PRISM Dev"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://prism-landing-production.up.railway.app/updates/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3Q0I5MUZGQzJFOEJGNjkKUldScHYrakMvNUhMNTl2Wmp0T0FnSzlaQkdGdkthYkp4dFl2VGhHRXNycFBLS3czTkl0endLOXEK"
    }
  }
}